@*
    Simple layout for all pages.
    Keeps navigation and structure minimal for student project.
*@

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - HeroEngine</title>
</head>

<body>

    <h2>HeroEngine</h2>

    <hr />

    <nav>
        <a asp-page="/Index">Home</a> |
        <a asp-page="/Heroes/Index">Heroes</a> |
        <a asp-page="/Combat">Combat</a> |
        <a asp-page="/Stats">Stats</a> |
        <a asp-page="/Files">Files</a>
    </nav>

    <hr />

    <div>
        @RenderBody()
    </div>

    <hr />

    <footer>
        <p>HeroEngine Web - 2026</p>
        <a asp-page="/Privacy">Privacy</a>
    </footer>

</body>
</html>