@page
@model HeroEngine.Web.Pages.StatsModel

<h1>Game Statistics</h1>

<hr />

<h2>Heroes by Class</h2>

@if (Model.HeroesByClass.Count == 0)
{
    <p>No hero data.</p>
}
else
{
    <ul>
        @foreach (var item in Model.HeroesByClass)
        {
            <li>
                <span style="color: blue;">@item.Key</span>:
                @item.Value
            </li>
        }
    </ul>
}

<hr />

<h2>Top Heroes</h2>

@if (Model.TopHeroes.Count == 0)
{
    <p>No heroes.</p>
}
else
{
    <ol>
        @foreach (var hero in Model.TopHeroes)
        {
            <li>
                <b>@hero.Name</b> (Lvl @hero.Lvl)
            </li>
        }
    </ol>
}

<hr />

<h2>Abilities by Type</h2>

@if (Model.AbilitiesByType.Count == 0)
{
    <p>No abilities.</p>
}
else
{
    <ul>
        @foreach (var item in Model.AbilitiesByType)
        {
            <li>
                <span style="color: green;">@item.Key</span>: @item.Value
            </li>
        }
    </ul>
}

<hr />

<h2>Legendary Abilities</h2>

@if (Model.LegendaryAbilities.Count == 0)
{
    <p>No legendary abilities.</p>
}
else
{
    <ul>
        @foreach (var ability in Model.LegendaryAbilities)
        {
            <li style="color: darkorange;">
                @ability.Name - @ability.Type (Cost: @ability.Cost)
            </li>
        }
    </ul>
}

<hr />

<h2>Average Damage per Class</h2>

@if (Model.AvgDamagePerClass.Count == 0)
{
    <p>No data.</p>
}
else
{
    <ul>
        @foreach (var item in Model.AvgDamagePerClass)
        {
            <li>
                @item.Key: <b>@item.Value.ToString("F1")</b>
            </li>
        }
    </ul>
}

<hr />

<h2>Combat History</h2>

@if (Model.CombatHistory.Count == 0)
{
    <p>No combats.</p>
}
else
{
    <ul>
        @foreach (var c in Model.CombatHistory)
        {
            <li style="color: @(c.HeroWon ? "green" : "red")">
                @c.Date.ToString("MM-dd HH:mm") -
                @(c.HeroWon ? "Win" : "Loss") vs @c.EnemyName
            </li>
        }
    </ul>
}